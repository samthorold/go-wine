package views

import (
	"strconv"
	"strings"

	"go-wine/internal/app"
)

templ TastingsPage(drinkers []DrinkerOption, model LogFormModel, tastings []app.TastingView) {
	@Layout("Tastings", SectionTastings, drinkers) {
		<h2>Log a tasting</h2>
		@LogForm(model)
		<h2>Your tastings</h2>
		@TastingList(tastings)
	}
}

// TastingList renders the #tastings region for first paint.
templ TastingList(tastings []app.TastingView) {
	@tastingList(tastings, false)
}

// TastingListOOB renders the same #tastings region marked for an
// out-of-band swap, used in the POST /tastings success response.
templ TastingListOOB(tastings []app.TastingView) {
	@tastingList(tastings, true)
}

// tastingList is the single source of the #tastings markup, so first-paint
// and OOB re-render cannot drift.
templ tastingList(tastings []app.TastingView, oob bool) {
	<div id="tastings" if oob { hx-swap-oob="true" }>
		if len(tastings) == 0 {
			<p class="empty">No tastings yet — log your first above.</p>
		} else {
			for _, t := range tastings {
				@TastingRow(t)
			}
		}
	</div>
}

templ LogForm(model LogFormModel) {
	<form id="log-form" class="measure" hx-post="/tastings" hx-target="#log-form" hx-swap="outerHTML">
		if msg := model.err(""); msg != "" {
			<p class="error banner" role="alert">{ msg }</p>
		}
		<label>
			Wine
			<select name="wine_id" required>
				// A disabled, empty-valued placeholder selected by default: Wine is
				// the one genuinely required field, so a blank form must not
				// pre-select a real Wine. Disabled + empty value makes HTML5
				// `required` block submit until a real Wine is chosen. See issue #40.
				<option value="" disabled selected?={ model.WineID == "" }>Choose a wine…</option>
				for _, w := range model.Wines {
					<option value={ w.ID } selected?={ w.ID == model.WineID }>{ w.Label }</option>
				}
			</select>
			if msg := model.err("wine_id"); msg != "" {
				<span class="error">{ msg }</span>
			}
		</label>
		<label>
			Vintage
			<input type="number" name="vintage" placeholder="e.g. 2019" min="1900" max="2100" value={ model.Vintage }/>
			<small>The year on the label — leave blank if unknown.</small>
			if msg := model.err("vintage"); msg != "" {
				<span class="error">{ msg }</span>
			}
		</label>
		<fieldset>
			<legend>Rating</legend>
			<span class="rating rating-input">
				for r := 5; r >= 1; r-- {
					<input type="radio" name="rating" value={ strconv.Itoa(r) } id={ "rating-" + strconv.Itoa(r) } checked?={ strconv.Itoa(r) == model.Rating }/>
					<label for={ "rating-" + strconv.Itoa(r) } aria-label={ strconv.Itoa(r) + " stars" }>★</label>
				}
				// The "no rating" option: a fresh tasting starts here, with no
				// stars filled. Rendered last so the reverse-order sibling
				// combinator never lights a star for it; the label is a small
				// "Clear" affordance to return to no rating without JS. See #39.
				<input type="radio" name="rating" value="" id="rating-none" checked?={ model.Rating == "" }/>
				<label for="rating-none" class="rating-clear">Clear</label>
			</span>
			if msg := model.err("rating"); msg != "" {
				<span class="error">{ msg }</span>
			}
		</fieldset>
		<label>
			Note
			<textarea name="note" rows="2" placeholder="cold night, lamb stew, cosy...">{ model.Note }</textarea>
		</label>
		@Companions(model)
		<button type="submit">Log tasting</button>
	</form>
}

// Companions renders the #companions region: the existing Companions to tick
// plus the "+ Add companion" control. It owns its id so first paint (embedded in
// LogForm) and the add-Companion re-render render from one component and cannot
// drift — see CLAUDE.md "a swap target owns its id ... rendered by one
// component". The add control is its own mutation against this region only: an
// explicit hx-post/hx-target/hx-swap that re-renders just #companions, so the
// in-progress Wine/rating/note the Drinker has entered is left untouched. It
// includes the ticked boxes so a newly-added Companion never wipes a prior pick.
// See issue #44.
templ Companions(model LogFormModel) {
	<fieldset id="companions">
		<legend>Companions</legend>
		if len(model.Companions) > 0 {
			for _, c := range model.Companions {
				<label class="companion">
					<input type="checkbox" name="companion_id" value={ c.ID } checked?={ model.companionSelected(c.ID) }/>
					{ c.Name }
				</label>
			}
		}
		<div role="group">
			<input type="text" name="new_companion" placeholder="Add someone — e.g. Alex" aria-label="New companion name" value={ model.NewCompanion }/>
			<button
				type="button"
				class="secondary"
				hx-post="/tastings/companions"
				hx-target="#companions"
				hx-swap="outerHTML"
				hx-include="#companions"
			>+ Add companion</button>
		</div>
		if msg := model.err("companion"); msg != "" {
			<span class="error">{ msg }</span>
		}
	</fieldset>
}

templ TastingRow(t app.TastingView) {
	<article>
		<strong>{ t.WineLabel }</strong>
		if t.Vintage != nil {
			<span>({ strconv.Itoa(*t.Vintage) })</span>
		}
		<span class="rating">{ ratingStars(t.Rating) }</span>
		<div>{ t.DrunkOn.Format("2 Jan 2006") }</div>
		if len(t.Companions) > 0 {
			<p class="companions">with { strings.Join(t.Companions, ", ") }</p>
		}
		if t.Note != "" {
			<p>{ t.Note }</p>
		}
	</article>
}
